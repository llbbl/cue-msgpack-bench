		"test": "vitest",
		"generate:msgpack": "bun run ./scripts/generate-msgpack.ts"
	},
	"dependencies": {
		"@msgpack/msgpack": "^3.0.0-beta.3",
		"cue-ts": "link:../cue-ts",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.4",
		"@tailwindcss/vite": "^4.1.4",
		"@types/node": "^25.5.0",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^6.0.1",
		"tailwindcss": "^4.1.4",
		"typescript": "~5.9.3",
		"vite": "^8.0.1",
		"vitest": "^3.2.1"
	},
