{
	"name": "cue-msgpack-bench",
	"private": true,
	"version": "0.1.0",
	"type": "module",
	"scripts": {
		"dev": "vite",
		"build": "tsc -b && vite build",
		"lint": "biome check ./src",
		"format": "biome format --write ./src",
